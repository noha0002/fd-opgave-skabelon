---
const { HeroTitleSmall, HeroTitle, HeroInformation } = Astro.props;
---

<div>
  <p>{HeroTitleSmall}</p>
  <h1>{HeroTitle}</h1>
  <h3>{HeroInformation}</h3>
</div>

<style>
  p {
    font-size: xx-small;
  }
  h1 {
    font-size: 2.5rem;
    font-weight: 800;
  }
  h3 {
    width: 70%;
    text-align: justify;
    margin: 0 auto;
    max-width: 800px;
  }
  div {
    text-align: center;
  }
  * + * {
    margin-bottom: 2%;
    line-height: 1.6;
  }
</style>
