---
//@ts-nocheck
import DynamicImage from "@components/helpers/DynamicImage.astro";
import caseStudy from "@data/caseStudy.json";
const { caseName, category, date, image, buttonLabel } = caseStudy.caseDetails;
---

<article>
  <header>
    <DynamicImage src={image} alt={caseName} />
    <div class="case-details">
      <dl>
        <div>
          <dt>Case Name</dt>
          <dd>{caseName}</dd>
        </div>
        <div>
          <dt>Category</dt>
          <dd class="category">{category}</dd>
        </div>
        <div>
          <dt>Date</dt>
          <dd class="date">{date}</dd>
        </div>
      </dl>
      <!-- husk at ændre tilbage til "#0" -->
      <a href="/single" class="button">{buttonLabel}</a>
    </div>
  </header>

  <div class="full-bleed">
    <div class="content">
      {
        caseStudy.sections.map((section) => (
          <section>
            {caseStudy.sections[0] === section ? (
              <h2>{section.title}</h2>
            ) : (
              <h3>{section.title}</h3>
            )}

            {Array.isArray(section.content) ? (
              <>
                {section.content.map((item) => (
                  <p>{item}</p>
                ))}
              </>
            ) : (
              <p>{section.content}</p>
            )}
            {section.highlights && (
              <ul>
                {section.highlights.map((highlight) => (
                  <li>{highlight}</li>
                ))}
              </ul>
            )}
            {section.image && (
              <DynamicImage
                src={section.image}
                alt={section.title}
                width={600}
                height={400}
              />
            )}
          </section>
        ))
      }
    </div>
  </div>
</article>

<style>
  header > img {
    border-radius: 42px;
  }
  section > img {
    align-self: center;
  }

  .full-bleed {
    display: flex;
    justify-content: center;

    margin-top: 100px;
    margin-bottom: 230px;
  }
  .content {
    display: flex;
    flex-direction: column;
    gap: 29px;
    max-width: 792px;
    margin-inline: auto;
  }

  article {
    max-width: 1200px;
    margin-inline: auto;
  }
  header {
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    position: relative;
    margin-top: 100px;
  }

  .case-details {
    display: grid;
    grid-template-columns: 2fr 1fr;
    width: 1028px;

    background: var(--color-ui-primary);
    color: var(--color-on-ui-primary);
    padding: 53px 60px;
    border-radius: 30px;

    position: absolute;
    bottom: -120px;
    left: 7%;
    justify-content: center;
  }

  dl {
    display: flex;
    gap: 100px;
  }
  dt {
    font-size: var(--step--4);
    font-weight: 700;
  }
  div:has(dd) {
    display: flex;
    flex-direction: column;
    gap: 11px;
  }

  .button {
    background: var(--color-action);
    color: var(--color-text);
    padding: 16px 33px;
    border-radius: var(--border-radius);
    align-self: center;

    font-size: var(--step--3);
    font-weight: 700;

    margin-left: auto;
  }

  section {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  h2 {
    font-size: var(--step-3);
    font-weight: 900;
  }
  h3 {
    font-size: var(--step-1);
    font-weight: 900;
  }
  section > p,
  li {
    line-height: 147.5%;
    color: var(--color-text-muted);
  }

  section:first-child {
    display: flex;
    flex-direction: column;
    gap: 15px;
    margin-top: 90px;

    ul {
      margin-top: 40px;
    }
  }
  section:nth-child(2) {
    display: flex;
    flex-direction: column;
    gap: 26px;
  }
  section:last-child {
    display: flex;
    flex-direction: column;
    gap: 38px;
  }

  @media (max-width: 768px) {
    article {
      padding-inline: 1rem;
    }

    header {
      margin-top: 40px;
    }

    .case-details {
      grid-template-columns: 1fr;
      width: 90%;
      left: 50%;
      transform: translateX(-50%);
      padding: 30px 25px;
      gap: 25px;
      bottom: -80px;
    }

    dl {
      flex-direction: column;
      gap: 25px;
    }

    .button {
      margin-left: 0;
      justify-self: start;
      width: fit-content;
    }

    .full-bleed {
      margin-top: 140px;
      margin-bottom: 120px;
      padding-inline: 1rem;
    }

    .content {
      gap: 24px;
      max-width: 100%;
    }

    section:first-child {
      margin-top: 40px;
    }

    section > img {
      width: 100%;
      height: auto;
    }
  }
</style>
