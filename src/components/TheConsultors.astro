---
import HeroTwoCard from "./HeroTwoCard.astro";
import ExpectCard from "./ExpectCard.astro";
import ConsultorsCard from "./ConsultorsCard.astro";
import insta from "@icons/instagram.svg";
import facebook from "@icons/facebook.svg";
import boss from "@assets/images/ceo2.png";
import img1 from "@assets/images/1.jpg";
import img2 from "@assets/images/2.png";
import img3 from "@assets/images/3.png";
import img4 from "@assets/images/4.png";
import img5 from "@assets/images/5.png";
import employees from "@data/employees.json";
import img1 from "@data/images/john.webp";
import img2 from "@data/images/daisy.webp";
import img3 from "@data/images/maya.webp";
import img4 from "@data/images/ryan.webp";
import img5 from "@data/images/lilly.webp";
import { Image } from "astro:assets";
---

<section>
  <div class="hero">
    <HeroTwoCard
      HeroTitleSmall="TEAM"
      HeroTitle="The Consultors"
      HeroInformation="Our success stems from the synergy between dedicated teams and our valued clients. We prioritize a company culture that fosters exceptional productivity, ensures customer satisfaction."
    />
  </div>
  <div>
    <div class="card">
      <ExpectCard
        HovedTitle="Meet Our Great Team"
        Information="Welcome to our amazing team! We are a group of passionate individuals dedicated to excellence and innovation. Each member brings unique skills and experiences, working together to achieve our goals. Join us as we embark on exciting projects and create lasting impacts."
      />
    </div>

    <div class="grid-3">
      {employees.map((person) => (
      <div>
        <a href={`/consultors/${person.slug}`}>
    <div class="grid-wrapper">
      <div class="grid-3">
        <div>
          <div class="image-wrapper" id="openBtn1">
            <img src={person.img} alt={person.title} />
            <p class="overlay-text">{person.title}</p>
          </div>
        </a>
        <ConsultorsCard
          ConsName={person.name}
          ConsIntroduction={person.description}
          insta={insta}
          facebook={facebook}
        />
      </div>
      ))}  
  </div> 
          <ConsultorsCard
            ConsName="Sarah Jasmine"
            ConsIntroduction="Driving innovation and leadership with a focus on strategic growth and impactful decisions."
            insta={insta}
            facebook={facebook}
          />
        </div>

        <div>
          <div class="image-wrapper" id="openBtn2">
            <Image src={img1} alt="Manager" />
            <p class="overlay-text">Manager</p>
          </div>
          <ConsultorsCard
            ConsName="John Carter"
            ConsIntroduction="Expert in operational efficiency, ensuring smooth processes and exceptional team performance."
            insta={insta}
            facebook={facebook}
          />
        </div>

        <div>
          <div class="image-wrapper" id="openBtn3">
            <Image src={img2} alt="Visionary" />
            <p class="overlay-text">Visionary</p>
          </div>
          <ConsultorsCard
            ConsName="Daisy Stella"
            ConsIntroduction="Inspiring creative solutions and forward-thinking approaches for groundbreaking projects."
            insta={insta}
            facebook={facebook}
          />
        </div>

        <div>
          <div class="image-wrapper" id="openBtn4">
            <Image src={img3} alt="Strategist" />
            <p class="overlay-text">Strategist</p>
          </div>
          <ConsultorsCard
            ConsName="Maya Elizabeth"
            ConsIntroduction="Crafting tailored strategies to empower business success and maximize market potential."
            insta={insta}
            facebook={facebook}
          />
        </div>

        <div>
          <div class="image-wrapper" id="openBtn5">
            <Image src={img4} alt="Director" />
            <p class="overlay-text">Director</p>
          </div>
          <ConsultorsCard
            ConsName="Ryan Jackson"
            ConsIntroduction="Leading with vision and precision to align organizational goals with long-term growth."
            insta={insta}
            facebook={facebook}
          />
        </div>

        <div>
          <div class="image-wrapper" id="openBtn6">
            <Image src={img5} alt="President" />
            <p class="overlay-text">President</p>
          </div>
          <ConsultorsCard
            ConsName="Lilly Victoria"
            ConsIntroduction="Championing collaboration and excellence to drive meaningful change and success."
            insta={insta}
            facebook={facebook}
          />
        </div>
      </div>
    </div>
  </div>

  <style>
    .card {
      margin-left: 25%;
      margin-bottom: 4%;
      margin-top: 4%;
    }
    .hero {
      background-color: #f9fafb;
      padding: 10%;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    .grid-wrapper {
      container-type: inline-size;
    }

    .grid-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      width: 50%;
      margin: 0 auto;
      gap: 51px;
      margin-bottom: 5%;
    }

    .grid-3 img {
      max-width: 366px;
      max-height: 392px;
      /* object-fit: cover; */
      /* display: block; */
      border-radius: 20px;
      gap: 5%;
      margin-bottom: 5%;
    }

    @container (width < 600px) {
      .grid-3 {
        grid-template-columns: 1fr;
        gap: 2%;
        margin-bottom: 50%;
      }
    }
    @container (width >= 2000px) {
      .grid-3 {
        grid-template-columns: repeat(6, 1fr);
        gap: 3%;
        width: 90%;
      }
    }

    .grid-3 img {
      width: 300px;
      height: 250px;
      object-fit: cover;
      display: block;
      border-radius: 12px;
    }
    .image-wrapper {
      position: relative;
      display: inline-block;
    }

    .overlay-text {
      position: absolute;
      top: 80%;
      left: 43%;
      color: white;
      background: black;
      padding: 7px;
      border-radius: 20px;
      width: 55%;
      font-weight: bold;
      font-size: 0.7rem;
      text-align: center;
    }
  </style>

  <script type="module">
    document.querySelector("#openBtn1").addEventListener("click", () => {
      document.querySelector("#dialog1").showModal();
    });

    document.querySelector("#openBtn2").addEventListener("click", () => {
      document.querySelector("#dialog2").showModal();
    });

    document.querySelector("#openBtn3").addEventListener("click", () => {
      document.querySelector("#dialog3").showModal();
    });

    document.querySelector("#openBtn4").addEventListener("click", () => {
      document.querySelector("#dialog4").showModal();
    });

    document.querySelector("#openBtn5").addEventListener("click", () => {
      document.querySelector("#dialog5").showModal();
    });

    document.querySelector("#openBtn6").addEventListener("click", () => {
      document.querySelector("#dialog6").showModal();
    });
  </script>
</section>
