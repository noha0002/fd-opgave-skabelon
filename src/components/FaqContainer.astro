---
import Faq from "./Faq.astro";
const { data, exclusive } = Astro.props;
---

<section class="accordion-container">
  <div>
    <p>FAQ</p>
    <h1>Customer Questions</h1>
  </div>

  <div>
    {data?.faq?.map((props) => <Faq {...props} {exclusive} />)}
  </div>
</section>

<style>
  div:has(h1) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }
  p {
    font-size: var(--step--1);
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 14.5%;
  }
  h1 {
    font-size: var(--step-4);
    color: var(--color-text);
    font-weight: 900;
  }

  section {
    padding-block: 3rem;
    background: #f5f5f5;
  }
  div {
    padding: 1rlh;
    max-width: 725px;
    margin-inline: auto;
  }
</style>
