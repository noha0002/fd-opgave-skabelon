---
const { FirstTitle, HovedTitle, Information } = Astro.props;
---

<div>
  <p>{FirstTitle}</p>
  <h1>{HovedTitle}</h1>
  <p>{Information}</p>
</div>

<style>
  h1 {
    font-size: xx-large;
    font-weight: 800;
    margin-top: var(--space-s);
    margin-bottom: 4%;
  }
  p {
    width: 370px;
    text-align: justify;
  }
</style>
