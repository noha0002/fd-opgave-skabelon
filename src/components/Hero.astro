---
import { Image } from "astro:assets";
import Services from "./Services.astro";
import BtnCARD from "@components/BtnCARD.astro";
import CEOImage from "@assets/images/ceo.webp";
---

<section class="hero">
  <div class="hero-content">
    <h1>
      <span class="underline">Empowering</span> Your Business Growth
    </h1>
    <p>
      Discover tailored strategies and expert insights to take your business to
      the next level. Let us help you navigate challenges and achieve
      sustainable success.
    </p>
    <div class="btn">
      <BtnCARD
        buttonClass="button-yellow"
        buttonBeskrivelse="Book a Meeting"
        buttonClass1="button-black"
        buttonBeskrivelse1="Learn More ehjsa"
      />
    </div>
  </div>
  <Image src={CEOImage} alt="CEO" />

  <Services />
</section>

<style>
  @layer components {
    @import url("https://fonts.googleapis.com/css2?family=Cabin:wght@400;500;600;700&display=swap");

    .btn {
      margin-top: 3%;
      justify-content: center;
      display: flex;
      width: 70%;
      gap: 5%;
    }

    .hero {
      display: grid;
      grid-template-columns: 1fr 1fr;
      background-color: #f3f4f6;
      padding: 2rem;
    }

    .hero:has(Img) Img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .hero-content {
      color: var(--color-neutrals, #eaedf1);
      background-color: var(--color-black, #000000);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
    }

    .hero:has(h1) h1 {
      font-size: xx-large;
      font-family: var(--font-cabin);
      width: 40%;
      font-weight: 700;
      padding-bottom: 2%;
    }
    .underline {
      display: inline-block;
      position: relative;
      border-bottom: 2px solid #ffd700;
    }

    .hero:has(p) p {
      width: 50%;
      text-align: justify;
    }
  }
</style>
