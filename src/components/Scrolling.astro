---
import ExpectCard from "./ExpectCard.astro";
import ScrollingCard from "./ScrollingCard.astro";
import { Image } from "astro:assets";
import cal from "@icons/cal.svg";
import card from "@icons/card.svg";
import law from "@icons/law.svg";
import money from "@icons/money.svg";
import left from "@icons/arrow-left.svg";
import right from "@icons/arrow--right.svg";
---

<body>
  <div class="ALL">
    <header>
      <ExpectCard
        FirstTitle="FINANCIAL TOOLS"
        HovedTitle="Financial Projections"
        Information="Financial projections are essential for planning and monitoring a company’s performance. They provide insights into potential revenue, expenses, and profitability over specific periods."
      />
    </header>

    <main>
      <div class="button">
        <button>
          <Image src={left} alt="Financial Ratios" />
        </button>
        <button>
          <Image src={right} alt="Financial Ratios" />
        </button>
      </div>
      <section>
        <ScrollingCard
          ScrollingTitle="The Balance Sheet"
          ScrollingBeskrivelse="The Balance Sheet is a summary of the assets and liabilities and equity of a business at a specific point of time."
        >
          <Image src={cal} alt="Balance Sheet" />
        </ScrollingCard>

        <ScrollingCard
          ScrollingTitle="Income Statement"
          ScrollingBeskrivelse="The Income (Profit and Loss) Statement, commonly referred to as the P&L statement, summarizes the revenue and expenses for a specific time period (one month, one quarter, one year, etc.)"
        >
          <Image src={card} alt="Income Statement" />
        </ScrollingCard>

        <ScrollingCard
          ScrollingTitle="Financial Plan"
          ScrollingBeskrivelse="Keep your information current and review the documents on a regular basis (monthly or more often if needed). Review them with key individuals within your company."
        >
          <Image src={law} alt="Financial Plan" />
        </ScrollingCard>

        <ScrollingCard
          ScrollingTitle="Financial Ratios"
          ScrollingBeskrivelse="Ratios are useful when comparing your company with the competition on financial performance and also when benchmarking the performance of your company."
        >
          <Image src={money} alt="Financial Ratios" />
        </ScrollingCard>
      </section>
    </main>
  </div>
</body>

<style>
  .button {
    display: flex;
    gap: 2%;
    justify-content: end;
    margin-right: 5%;
    img {
      width: 20px;
      height: auto;
      filter: brightness(0) invert(1); 
    }
  }

  button {
    background-color: rgb(0, 0, 0);
    border-radius: 50px;
    padding: 1%;
  }

  .ALL {
    background-color: #f9fafb;
    margin-bottom: 5%;
    overflow-x: hidden;
    padding-bottom: 6%;
  }
  header {
    margin-left: 20%;
    padding-top: 5%;
  }
  section {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 5%;
    margin-top: 3%;
    width: 90%;

    margin-left: 20%;

    img {
      width: 25px;
      height: auto;
      margin-bottom: 5%;
    }
  }
</style>
