---
import Logo from "@icons/logo.svg";
---

<footer>
  <div>
    <Logo />
    <p>©2025 Consultalk. All rights reserved</p>
    <p>Terms of Service | Privacy Policy</p>
  </div>
</footer>

<style>
  @layer components {
    footer {
      background: var(--color-ui-primary);
      color: var(--color-text-weak);
      padding: 38px;
    }

    div {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;

      margin: 0 auto;
      max-width: 1200px;

      p {
        font-size: var(--step--1);
      }
    }
  }

  @media (max-width: 768px) {
    footer {
      padding: 30px 20px;
    }

    footer > div {
      flex-direction: column;
      text-align: center;
      gap: 15px;
    }

    footer p {
      font-size: var(--step--2);
    }

    footer svg {
      width: 120px;
      height: auto;
    }
  }
</style>
