---
const { NameIntro, IDIntro, Introduction } = Astro.props;
---

<div>
  <h1>{NameIntro}</h1>
  <h2>{IDIntro}</h2>
  <p>{Introduction}</p>
</div>
<style>
  h1 {
    font-size: larger;
    font-weight: 800;
    margin-top: 5%;
  }
  h2 {
    font-weight: 800;
  }
  p{
    width: 80%;
  }
  div *{
    margin-bottom: 5%;
  }
</style>
